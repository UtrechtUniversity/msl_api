<https://registry.epos-eu.org/ncl/FAIR/porefluids>
  a skos:ConceptScheme ;
  skos:prefLabel "Pore fluid" ;
  skos:hasTopConcept <https://registry.epos-eu.org/ncl/FAIR/porefluids/vacuum>, <https://registry.epos-eu.org/ncl/FAIR/porefluids/solid_phase>, <https://registry.epos-eu.org/ncl/FAIR/porefluids/liquid_phase>, <https://registry.epos-eu.org/ncl/FAIR/porefluids/gas_phase> ;
  reg:inverseMembershipPredicate skos:inScheme ;
  ui:hierarchyChildProperty skos:narrower ;
  ui:hierarchyRootProperty skos:topConceptOf ;
  ldp:isMemberOfRelation skos:inScheme .

